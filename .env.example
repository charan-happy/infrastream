# Aiven Kafka (Client Certificate Auth)
KAFKA_BROKER=infrastream-kafka-infrastream.i.aivencloud.com:15963
# Certificates are read from certificates/ directory automatically
# Or override paths:
# KAFKA_KAFKA-CA.PEM_PATH=/path/to/kafka-ca.pem
# KAFKA_KAFKA-ACCESS-CERTIFICATE.PEM_PATH=/path/to/kafka-access-certificate.pem
# KAFKA_KAFKA-ACCESS.PEM_PATH=/path/to/kafka-access.pem

# Aiven PostgreSQL
PG_CONNECTION_URI=postgres://avnadmin:your-password@infrastream-pg-infrastream.d.aivencloud.com:15961/defaultdb?sslmode=require

# Aiven Valkey
VALKEY_URI=rediss://default:your-password@infrastream-valkey-infrastream.i.aivencloud.com:15962

# GitHub Webhook Secret (optional)
GITHUB_WEBHOOK_SECRET=your-webhook-secret
